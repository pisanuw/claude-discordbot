# ── Discord ───────────────────────────────────────────────────────────────────
# From the Discord Developer Portal → your application
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# ── Security ──────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting user API keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit this value. Rotate it if compromised (all stored user keys will need re-entry).
ENCRYPTION_KEY=your_64_char_hex_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Max tokens per response (default: 2048)
# MAX_TOKENS=2048

# SQLite database path (default: /data/bot.db in production, ./bot.db locally)
# DB_PATH=/data/bot.db

# GitHub personal access token (optional but recommended for /review command)
# Raises rate limit from 60 to 5000 requests/hour.
# Create a fine-grained token with read-only "Contents" scope.
# GITHUB_TOKEN=github_pat_...

# Users must provide their own Anthropic key with /claude-mykey set.
# Users must provide their own E2B key with /claude-e2bkey set for /claude-run.
